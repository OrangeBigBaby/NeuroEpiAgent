# NeuroSurgEpiAgent — local environment template
# =================================================
# Copy this file to `.env` (which is git-ignored) and fill in the absolute
# paths to the local SEER and CDC WONDER export roots on the machine that will
# run the inspection / case-study scripts.
#
# DO NOT commit `.env`. Only this `.env.example` template is tracked.

# Local SEER*Stat export root (directory containing export_C*.csv).
NEUROSURG_EPI_SEER_ROOT=<local-seer-directory>

# Local CDC WONDER export root (directory containing the public aggregate
# wonder_*.csv / wonder_*.xls files). The base directory name itself is
# sensitive only insofar as it reveals a local layout; the adapter never
# echoes it back into any metadata output.
NEUROSURG_EPI_CDC_WONDER_ROOT=<local-cdc-wonder-directory>